datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

generator client {
  provider = "prisma-client-js"
}

// ? ENUMS
enum Role {
  ADMIN
  SISWA
  GURU
  ORANGTUA

  @@schema("public")
}

enum JenisKelamin {
  UNKNOWN
  MALE
  FEMALE

  @@schema("public")
}

enum GolonganDarah {
  UNKNOWN
  A
  B
  AB
  O

  @@schema("public")
}

enum Kewarganegaraan {
  UNKNOWN
  INDONESIA
  FOREIGN

  @@schema("public")
}

enum SemesterAjaranUrutan {
  SATU
  DUA

  @@schema("public")
}

enum TipeAbsensi {
  UNKNOWN
  HADIR
  IZIN
  SAKIT

  @@schema("public")
}

enum AssignmentSubmissionType {
  LONG_TEXT
  FILE_UPLOAD
  TIME_STAMP

  @@schema("public")
}

enum AssignmentSubmissionStatus {
  ASSIGNED
  ON_PROGRESS
  SUBMITTED
  SCORED

  @@schema("public")
}

enum ReportStatus {
  DRAFT
  OPEN
  CLOSED

  @@schema("public")
}

// ? =====

// ? TABLES
model Akun {
  id                             String                     @id @default(cuid())
  // ? credentials
  username                       String                     @unique
  password                       String
  role                           Role                       @default(SISWA)
  nip                            String?
  // ? general
  displayName                    String?
  firstName                      String
  lastName                       String
  email                          String?
  tanggalLahir                   DateTime?
  tempatLahir                    String?
  jenisKelamin                   JenisKelamin               @default(UNKNOWN)
  alamat                         String?
  agama                          String?
  golonganDarah                  GolonganDarah              @default(UNKNOWN)
  kewarganegaraan                Kewarganegaraan            @default(UNKNOWN)
  point                          Int                        @default(0)
  profileImageObjectPath         String?
  // ? meta data
  updatedAt                      DateTime                   @default(now())
  createdAt                      DateTime                   @default(now())
  deletedAt                      DateTime?
  createdById                    String?
  createdBy                      Akun?                      @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById                 String?
  lastUpdateBy                   Akun?                      @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")
  // ? action relations
  akunCreator                    Akun[]                     @relation(name: "createdBy")
  akunUpdator                    Akun[]                     @relation(name: "lastUpdateBy")
  tempAkunCreator                TempAkun[]                 @relation(name: "createdBy")
  tahunAjaranCreator             TahunAjaran[]              @relation(name: "createdBy")
  tahunAjaranUpdator             TahunAjaran[]              @relation(name: "lastUpdateBy")
  semesterAjaranCreator          SemesterAjaran[]           @relation(name: "createdBy")
  semesterAjaranUpdator          SemesterAjaran[]           @relation(name: "lastUpdateBy")
  kelasCreator                   Kelas[]                    @relation(name: "createdBy")
  kelasUpdator                   Kelas[]                    @relation(name: "lastUpdateBy")
  mataPelajaranCreator           MataPelajaran[]            @relation(name: "createdBy")
  mataPelajaranUpdator           MataPelajaran[]            @relation(name: "lastUpdateBy")
  ekstrakulikulerCreator         Ekstrakulikuler[]          @relation(name: "createdBy")
  ekstrakulikulerUpdator         Ekstrakulikuler[]          @relation(name: "lastUpdateBy")
  pengumumanCreator              Pengumuman[]               @relation(name: "createdBy")
  pengumumanUpdator              Pengumuman[]               @relation(name: "lastUpdateBy")
  absensiCreator                 Absensi[]                  @relation(name: "createdBy")
  absensiUpdator                 Absensi[]                  @relation(name: "lastUpdateBy")
  assignmentCreator              Assignment[]               @relation(name: "createdBy")
  assignmentUpdator              Assignment[]               @relation(name: "lastUpdateBy")
  mataPelajaranAttachmentCreator MataPelajaranAttachment[]  @relation(name: "createdBy")
  mataPelajaranAttachmentUpdator MataPelajaranAttachment[]  @relation(name: "lastUpdateBy")
  pelanggaranCreator             PelanggaranPerMapel[]      @relation(name: "createdBy")
  pelanggaranUpdator             PelanggaranPerMapel[]      @relation(name: "lastUpdateBy")
  beritaAcaraCreator             MataPelajaranBeritaAcara[] @relation(name: "createdBy")
  beritaAcaraUpdator             MataPelajaranBeritaAcara[] @relation(name: "lastUpdateBy")
  importExcelTemplateCreator     ImportExcelTemplate[]      @relation(name: "createdBy")
  importExcelTemplateUpdator     ImportExcelTemplate[]      @relation(name: "lastUpdateBy")
  academicCalendarEventCreator   AcademicCalendarEvent[]    @relation(name: "createdBy")
  academicCalendarEventUpdator   AcademicCalendarEvent[]    @relation(name: "lastUpdateBy")
  // ? relations
  siswaPerKelasDanSemester       SiswaPerKelasDanSemester[]
  waliKelas                      Kelas[]                    @relation(name: "wali")
  guruMataPelajaran              MataPelajaran[]
  pengajarEkstrakulikuler        Ekstrakulikuler[]          @relation(name: "pengajar")
  siswaPerEkstrakulikuler        SiswaPerEkstrakulikuler[]
  absensiSiswaPerKelas           AbsensiXSiswa[]
  assignmentSubmissions          AssignmentSubmission[]
  penilaians                     Penilaian[]
  pelanggaransPerMapel           PelanggaranPerMapel[]
  children                       AkunChildren[]             @relation(name: "children")
  parents                        AkunChildren[]             @relation(name: "parents")
  penilaiansExtrakulikuler       PenilaianExtrakulikuler[]
  studentReports                 StudentReport[]            @relation(name: "studentReports")
  studentSubjectReports          StudentSubjectReport[]     @relation(name: "studentSubjectReports")

  @@index([role])
  @@schema("public")
}

model TempAkun {
  id              String          @id @default(cuid())
  username        String
  password        String
  role            Role            @default(SISWA)
  displayName     String?
  firstName       String
  lastName        String
  email           String?
  tanggalLahir    DateTime?
  tempatLahir     String?
  jenisKelamin    JenisKelamin    @default(UNKNOWN)
  alamat          String?
  agama           String?
  golonganDarah   GolonganDarah   @default(UNKNOWN)
  kewarganegaraan Kewarganegaraan @default(UNKNOWN)
  // ? meta data
  createdAt       DateTime        @default(now())
  createdById     String?
  createdBy       Akun?           @relation(fields: [createdById], references: [id], name: "createdBy")

  @@schema("public")
}

model Hour {
  id                     String                     @id
  // ? credentials
  sequenceNumber         Int                        @default(autoincrement())
  label                  String
  // ? relations
  jadwalPelajarans       JadwalPelajaran[]
  mapelBeritaAcarasStart MataPelajaranBeritaAcara[] @relation(name: "start")
  mapelBeritaAcarasEnd   MataPelajaranBeritaAcara[] @relation(name: "end")

  @@schema("public")
}

model Days {
  id                String                     @id
  // ? credentials
  sequenceNumber    Int                        @default(autoincrement())
  label             String
  // ? relations
  jadwalPelajarans  JadwalPelajaran[]
  mapelBeritaAcaras MataPelajaranBeritaAcara[]

  @@schema("public")
}

model TahunAjaran {
  id                       String                  @id @default(cuid())
  // ? credentials
  nama                     String
  tahunMulai               DateTime
  tahunBerakhir            DateTime
  academicCalendarEmbedUrl String?
  // ? meta data
  updatedAt                DateTime                @default(now())
  createdAt                DateTime                @default(now())
  deletedAt                DateTime?
  createdById              String?
  createdBy                Akun?                   @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById           String?
  lastUpdateBy             Akun?                   @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")
  // ? relations
  semesterAjaran           SemesterAjaran[]
  kelas                    Kelas[]
  ekstrakulikuler          Ekstrakulikuler[]
  academicCalendarEvents   AcademicCalendarEvent[]

  @@schema("public")
}

model SemesterAjaran {
  id                       String                     @id @default(cuid())
  // ? credentials
  urutan                   SemesterAjaranUrutan       @default(SATU)
  // ? foreign
  tahunAjaranId            String
  tahunAjaran              TahunAjaran                @relation(fields: [tahunAjaranId], references: [id])
  // ? meta data
  updatedAt                DateTime                   @default(now())
  createdAt                DateTime                   @default(now())
  deletedAt                DateTime?
  createdById              String?
  createdBy                Akun?                      @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById           String?
  lastUpdateBy             Akun?                      @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")
  // ? relations
  mataPelajaran            MataPelajaran[]
  siswaPerKelasDanSemester SiswaPerKelasDanSemester[]
  jadwalPelajarans         JadwalPelajaran[]
  absensis                 Absensi[]
  reportConfigs            ReportConfig[]
  studentReports           StudentReport[]
  studentSubjectReports    StudentSubjectReport[]

  @@schema("public")
}

model Kelas {
  id                        String                     @id @default(cuid())
  // ? credentials
  nama                      String
  // ? foreign
  tahunAjaranId             String
  tahunAjaran               TahunAjaran                @relation(fields: [tahunAjaranId], references: [id])
  waliId                    String?
  wali                      Akun?                      @relation(fields: [waliId], references: [id], name: "wali")
  // ? meta data
  updatedAt                 DateTime                   @default(now())
  createdAt                 DateTime                   @default(now())
  deletedAt                 DateTime?
  createdById               String?
  createdBy                 Akun?                      @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById            String?
  lastUpdateBy              Akun?                      @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")
  // ? relations
  siswaPerKelasDanSemester  SiswaPerKelasDanSemester[]
  jadwalPelajarans          JadwalPelajaran[]
  absensis                  Absensi[]
  assignments               Assignment[]
  penilaians                Penilaian[]
  mataPelajaranAttachments  MataPelajaranAttachment[]
  pelanggaransPerMapel      PelanggaranPerMapel[]
  mataPelajaranBeritaAcaras MataPelajaranBeritaAcara[]
  reportConfigs             ReportConfig[]

  @@index([tahunAjaranId])
  @@schema("public")
}

model MataPelajaran {
  id                       String                     @id @default(cuid())
  // ? credentials
  nama                     String
  // ? general
  kkm                      Int                        @default(75)
  jumlahSesi               Int                        @default(1)
  // ? foreign
  guruId                   String?
  guru                     Akun?                      @relation(fields: [guruId], references: [id])
  semesterAjaranId         String
  semesterAjaran           SemesterAjaran             @relation(fields: [semesterAjaranId], references: [id])
  // ? meta data
  updatedAt                DateTime                   @default(now())
  createdAt                DateTime                   @default(now())
  deletedAt                DateTime?
  createdById              String?
  createdBy                Akun?                      @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById           String?
  lastUpdateBy             Akun?                      @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")
  // ? relations
  jadwalPelajarans         JadwalPelajaran[]
  assignments              Assignment[]
  penilaians               Penilaian[]
  mataPelajaranAttachments MataPelajaranAttachment[]
  pelanggarans             PelanggaranPerMapel[]
  beritaAcaras             MataPelajaranBeritaAcara[]
  studentSubjectReports    StudentSubjectReport[]

  @@schema("public")
}

model Ekstrakulikuler {
  id                       String                    @id @default(cuid())
  // ? credentials
  nama                     String
  // ? general
  ruangan                  String?
  // ? foreign
  tahunAjaranId            String
  tahunAjaran              TahunAjaran               @relation(fields: [tahunAjaranId], references: [id])
  pengajarId               String?
  pengajar                 Akun?                     @relation(fields: [pengajarId], references: [id], name: "pengajar")
  // ? meta data
  updatedAt                DateTime                  @default(now())
  createdAt                DateTime                  @default(now())
  deletedAt                DateTime?
  createdById              String?
  createdBy                Akun?                     @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById           String?
  lastUpdateBy             Akun?                     @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")
  // ? relations
  siswaPerEkstrakulikuler  SiswaPerEkstrakulikuler[]
  penilaiansExtrakulikuler PenilaianExtrakulikuler[]

  @@schema("public")
}

model Pengumuman {
  id             String    @id @default(cuid())
  // ? credentials
  nama           String
  // ? general
  content        String
  // ? meta data
  updatedAt      DateTime  @default(now())
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?
  createdById    String?
  createdBy      Akun?     @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById String?
  lastUpdateBy   Akun?     @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")

  @@schema("public")
}

model Absensi {
  id               String          @id @default(cuid())
  // ? credentials
  label            String
  remarks          String?
  tanggal          DateTime
  tanggalText      String // Versi text dari tanggal
  kelasId          String
  kelas            Kelas           @relation(fields: [kelasId], references: [id])
  semesterAjaranId String
  semesterAjaran   SemesterAjaran  @relation(fields: [semesterAjaranId], references: [id])
  // ? meta data
  updatedAt        DateTime        @default(now())
  createdAt        DateTime        @default(now())
  createdById      String?
  createdBy        Akun?           @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById   String?
  lastUpdateBy     Akun?           @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")
  // ? relations
  siswaTerabsen    AbsensiXSiswa[]

  @@index([kelasId])
  @@index([semesterAjaranId])
  @@index([tanggal])
  @@index([kelasId, tanggal])
  @@schema("public")
}

model Assignment {
  id                    String                   @id @default(cuid())
  // ? credentials
  mataPelajaranId       String
  mataPelajaran         MataPelajaran            @relation(fields: [mataPelajaranId], references: [id])
  kelasId               String
  kelas                 Kelas                    @relation(fields: [kelasId], references: [id])
  // ? general
  title                 String
  description           String?
  tanggalMulai          DateTime
  tanggalBerakhir       DateTime
  isSubmitable          Boolean                  @default(false)
  submissionType        AssignmentSubmissionType @default(FILE_UPLOAD)
  // ? meta data
  updatedAt             DateTime                 @default(now())
  createdAt             DateTime                 @default(now())
  createdById           String?
  createdBy             Akun?                    @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById        String?
  lastUpdateBy          Akun?                    @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")
  // ? connected kompetensi
  connectedKompetensiId String?
  connectedKompetensi   Kompetensi?              @relation(fields: [connectedKompetensiId], references: [id])
  // ? relations
  submissions           AssignmentSubmission[]

  @@index([kelasId])
  @@index([mataPelajaranId])
  @@schema("public")
}

model MataPelajaranAttachment {
  id              String        @id @default(cuid())
  // ? credentials
  kelasId         String
  kelas           Kelas         @relation(fields: [kelasId], references: [id])
  mataPelajaranId String
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id])
  // ? general
  title           String
  description     String?
  path            String
  // ? meta data
  updatedAt       DateTime      @default(now())
  createdAt       DateTime      @default(now())
  createdById     String?
  createdBy       Akun?         @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById  String?
  lastUpdateBy    Akun?         @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")

  @@schema("public")
}

model Kompetensi {
  id             String       @id
  // ? credentials
  sequenceNumber Int          @default(autoincrement())
  label          String
  isConnectable  Boolean      @default(false)
  // ? relations
  penilaians     Penilaian[]
  assignments    Assignment[]
  // ? meta data
  deletedAt      DateTime?

  @@schema("public")
}

model Penilaian {
  id              Int           @id @default(autoincrement())
  // ? credentials
  kelasId         String
  kelas           Kelas         @relation(fields: [kelasId], references: [id])
  mataPelajaranId String
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id])
  kompetensiId    String
  kompetensi      Kompetensi    @relation(fields: [kompetensiId], references: [id])
  siswaId         String
  siswa           Akun          @relation(fields: [siswaId], references: [id])
  // ? general
  nilai           Decimal?      @default(0)
  remark          String?
  // ? meta data
  updatedAt       DateTime      @default(now())
  createdAt       DateTime      @default(now())

  @@unique([kelasId, mataPelajaranId, kompetensiId, siswaId])
  @@index([kelasId])
  @@index([mataPelajaranId])
  @@index([siswaId])
  @@index([kompetensiId])
  @@index([kelasId, mataPelajaranId])
  @@index([siswaId, kelasId])
  @@schema("public")
}

model PelanggaranPerMapel {
  id              String        @id @default(cuid())
  // ? credentials
  kelasId         String
  kelas           Kelas         @relation(fields: [kelasId], references: [id])
  mataPelajaranId String
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id])
  siswaId         String
  siswa           Akun          @relation(fields: [siswaId], references: [id])
  // ? general
  poin            Int           @default(0)
  remark          String?
  // ? meta data
  updatedAt       DateTime      @default(now())
  createdAt       DateTime      @default(now())
  deletedAt       DateTime?
  createdById     String?
  createdBy       Akun?         @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById  String?
  lastUpdateBy    Akun?         @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")

  @@schema("public")
}

model MataPelajaranBeritaAcara {
  id              String        @id @default(cuid())
  // ? credentials
  kelasId         String
  kelas           Kelas         @relation(fields: [kelasId], references: [id])
  mataPelajaranId String
  mataPelajaran   MataPelajaran @relation(fields: [mataPelajaranId], references: [id])
  dayId           String
  day             Days          @relation(fields: [dayId], references: [id])
  hourStartId     String
  hourStart       Hour          @relation(fields: [hourStartId], references: [id], name: "start")
  hourEndId       String
  hourEnd         Hour          @relation(fields: [hourEndId], references: [id], name: "end")
  // ? general
  title           String
  remark          String
  // ? meta data
  updatedAt       DateTime      @default(now())
  createdAt       DateTime      @default(now())
  createdById     String?
  createdBy       Akun?         @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById  String?
  lastUpdateBy    Akun?         @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")

  @@schema("public")
}

model PenilaianExtrakulikuler {
  id                          Int                       @id @default(autoincrement())
  // ? credentials
  ekstrakulikulerId           String
  ekstrakulikuler             Ekstrakulikuler           @relation(fields: [ekstrakulikulerId], references: [id])
  kompetensiEkstrakulikulerId String
  kompetensiEkstrakulikuler   KompetensiEkstrakulikuler @relation(fields: [kompetensiEkstrakulikulerId], references: [id])
  siswaId                     String
  siswa                       Akun                      @relation(fields: [siswaId], references: [id])
  // ? general
  nilai                       Decimal?                  @default(0)
  remark                      String?
  // ? meta data
  updatedAt                   DateTime                  @default(now())
  createdAt                   DateTime                  @default(now())

  @@unique([ekstrakulikulerId, kompetensiEkstrakulikulerId, siswaId])
  @@index([ekstrakulikulerId])
  @@index([kompetensiEkstrakulikulerId])
  @@index([siswaId])
  @@index([siswaId, ekstrakulikulerId])
  @@schema("public")
}

model KompetensiEkstrakulikuler {
  id                        String                    @id
  // ? credentials
  sequenceNumber            Int                       @default(autoincrement())
  label                     String
  // ? relations
  penilaiansEkstrakulikuler PenilaianExtrakulikuler[]
  // ? meta data
  deletedAt                 DateTime?

  @@schema("public")
}

model ImportExcelTemplate {
  id             String   @id @default(cuid())
  // ? general
  title          String
  filePath       String? // ? Public object url
  remark         String?
  // ? meta data
  updatedAt      DateTime @default(now())
  createdAt      DateTime @default(now())
  createdById    String?
  createdBy      Akun?    @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById String?
  lastUpdateBy   Akun?    @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")

  @@schema("public")
}

model AcademicCalendarEvent {
  id             String      @id @default(cuid())
  // ? general
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime
  isAllDay       Boolean     @default(true)
  googleEventId  String?
  // ? relations
  tahunAjaranId  String
  tahunAjaran    TahunAjaran @relation(fields: [tahunAjaranId], references: [id])
  // ? meta data
  updatedAt      DateTime    @default(now())
  createdAt      DateTime    @default(now())
  createdById    String?
  createdBy      Akun?       @relation(fields: [createdById], references: [id], name: "createdBy")
  lastUpdateById String?
  lastUpdateBy   Akun?       @relation(fields: [lastUpdateById], references: [id], name: "lastUpdateBy")

  @@schema("public")
}

model ReportConfig {
  id               String         @id @default(cuid())
  // ? credentials
  kelasId          String
  kelas            Kelas          @relation(fields: [kelasId], references: [id])
  semesterAjaranId String
  semesterAjaran   SemesterAjaran @relation(fields: [semesterAjaranId], references: [id])
  status           ReportStatus   @default(DRAFT)
  // ? meta data
  updatedAt        DateTime       @default(now())
  createdAt        DateTime       @default(now())

  @@unique([kelasId, semesterAjaranId])
  @@index([kelasId])
  @@index([semesterAjaranId])
  @@schema("public")
}

model StudentReport {
  id                   String         @id @default(cuid())
  // ? credentials
  siswaId              String
  siswa                Akun           @relation(fields: [siswaId], references: [id], name: "studentReports")
  semesterAjaranId     String
  semesterAjaran       SemesterAjaran @relation(fields: [semesterAjaranId], references: [id])
  // ? general
  homeroomTeacherNote  String?
  // ? meta data
  updatedAt            DateTime       @default(now())
  createdAt            DateTime       @default(now())

  @@unique([siswaId, semesterAjaranId])
  @@index([siswaId])
  @@index([semesterAjaranId])
  @@schema("public")
}

model StudentSubjectReport {
  id               String        @id @default(cuid())
  // ? credentials
  siswaId          String
  siswa            Akun          @relation(fields: [siswaId], references: [id], name: "studentSubjectReports")
  semesterAjaranId String
  semesterAjaran   SemesterAjaran @relation(fields: [semesterAjaranId], references: [id])
  mataPelajaranId  String
  mataPelajaran    MataPelajaran @relation(fields: [mataPelajaranId], references: [id])
  // ? general
  description      String?
  // ? meta data
  updatedAt        DateTime      @default(now())
  createdAt        DateTime      @default(now())

  @@unique([siswaId, semesterAjaranId, mataPelajaranId])
  @@index([siswaId])
  @@index([semesterAjaranId])
  @@index([mataPelajaranId])
  @@schema("public")
}

// ? ======

// ? RELATIONS
model JadwalPelajaran {
  id               Int            @id @default(autoincrement())
  // ? identifier
  mataPelajaranId  String
  mataPelajaran    MataPelajaran  @relation(fields: [mataPelajaranId], references: [id])
  dayId            String
  day              Days           @relation(fields: [dayId], references: [id])
  hourId           String
  hour             Hour           @relation(fields: [hourId], references: [id])
  // ? semester ajaran berguna untuk mempermudah validasi tabrakan jadwal
  semesterAjaranId String
  semesterAjaran   SemesterAjaran @relation(fields: [semesterAjaranId], references: [id])
  // ? foreign
  kelasId          String
  kelas            Kelas          @relation(fields: [kelasId], references: [id])

  @@unique([dayId, hourId, kelasId, semesterAjaranId])
  @@index([kelasId])
  @@index([semesterAjaranId])
  @@index([dayId])
  @@index([hourId])
  @@index([kelasId, semesterAjaranId])
  @@schema("public")
}

model SiswaPerKelasDanSemester {
  id               Int            @id @default(autoincrement())
  nomorAbsen       Int?
  // ? foreign
  siswaId          String
  siswa            Akun           @relation(fields: [siswaId], references: [id])
  kelasId          String
  kelas            Kelas          @relation(fields: [kelasId], references: [id])
  semesterAjaranId String
  semesterAjaran   SemesterAjaran @relation(fields: [semesterAjaranId], references: [id])

  @@unique([siswaId, kelasId, semesterAjaranId, nomorAbsen])
  @@index([nomorAbsen])
  @@index([siswaId])
  @@index([kelasId])
  @@index([semesterAjaranId])
  @@schema("public")
}

model SiswaPerEkstrakulikuler {
  id                Int             @id @default(autoincrement())
  // ? foreign
  siswaId           String
  siswa             Akun            @relation(fields: [siswaId], references: [id])
  ekstrakulikulerId String
  ekstrakulikuler   Ekstrakulikuler @relation(fields: [ekstrakulikulerId], references: [id])

  @@unique([siswaId, ekstrakulikulerId])
  @@index([siswaId])
  @@index([ekstrakulikulerId])
  @@schema("public")
}

model AbsensiXSiswa {
  id        Int         @id @default(autoincrement())
  // ? credentials
  absensiId String
  absensi   Absensi     @relation(fields: [absensiId], references: [id])
  siswaId   String
  siswa     Akun        @relation(fields: [siswaId], references: [id])
  // ? general
  tipe      TipeAbsensi @default(UNKNOWN)

  @@index([absensiId])
  @@index([siswaId])
  @@schema("public")
}

model AssignmentSubmission {
  id               Int                        @id @default(autoincrement())
  // ? credentials
  assignmentId     String
  assignment       Assignment                 @relation(fields: [assignmentId], references: [id])
  siswaId          String
  siswa            Akun                       @relation(fields: [siswaId], references: [id])
  // ? general
  submissionStatus AssignmentSubmissionStatus @default(ASSIGNED)
  answer           String?
  fileDownloadUrl  String?
  fileObjectPath   String?
  remarksSiswa     String?
  remarksGuru      String?
  // ? meta data
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @default(now())

  @@unique([assignmentId, siswaId])
  @@index([assignmentId])
  @@index([siswaId])
  @@schema("public")
}

model AkunChildren {
  id        String   @id @default(cuid())
  // ? credentials
  parentId  String
  parent    Akun     @relation(fields: [parentId], references: [id], name: "children")
  siswaId   String
  siswa     Akun     @relation(fields: [siswaId], references: [id], name: "parents")
  // ? meta data
  createdAt DateTime @default(now())

  @@unique([parentId, siswaId])
  @@index([parentId])
  @@index([siswaId])
  @@schema("public")
}

